# =============================================================================
# Snowflake (camada ouro) — usado APENAS no servidor.
# NUNCA prefixe estas variáveis com NEXT_PUBLIC_. Elas são secretas.
# Configure-as localmente em .env.local e na Vercel em Project Settings > Environment Variables.
# =============================================================================
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT
# Chave privada PEM (key-pair auth). Em ambiente de deploy, cole o conteúdo PEM
# completo (pode usar \n literais; o client converte para quebras de linha reais).
SNOWFLAKE_PRIVATE_KEY=
# Opcional: somente se a chave privada estiver protegida por passphrase.
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# =============================================================================
# Dashboard
# =============================================================================
# Tempo de cache (segundos) para o data-fetching server-side dos dashboards.
DASHBOARD_CACHE_SECONDS=300

# =============================================================================
# Autenticação (Auth.js / NextAuth v5 + Google OAuth) — usado APENAS no servidor.
# NUNCA prefixe estas variáveis com NEXT_PUBLIC_. São secretas.
# Guia: docs/10-autenticacao-auth-js.md, docs/11-google-oauth-setup.md.
# =============================================================================
# Segredo de assinatura da sessão. Gere com: npx auth secret
AUTH_SECRET=
# Credenciais do cliente OAuth do Google (Google Cloud Console).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# URL pública da app (ex.: https://<dashboard>.vercel.app). Local pode omitir.
AUTH_URL=
# Necessário atrás de proxy (Vercel).
AUTH_TRUST_HOST=true
# Domínios corporativos aceitos (lista separada por vírgula). Se omitido, usa o
# default: suno.com.br,sunoresearch.com.br
AUTH_ALLOWED_DOMAINS=suno.com.br,sunoresearch.com.br
# Origem(ns) do DataHub autorizadas a embutir o dashboard via iframe (separadas
# por espaço). Ex.: https://datahub.suno.com.br. Sem valor = bloqueia iframe.
DATAHUB_FRAME_ANCESTORS=

# =============================================================================
# App (pode ser público — NÃO coloque segredos aqui)
# =============================================================================
NEXT_PUBLIC_APP_NAME=Power BI to Web Boilerplate
