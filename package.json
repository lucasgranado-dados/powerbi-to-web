{
  "name": "powerbi-to-web-boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "Boilerplate interno para migração semi-automatizada de dashboards Power BI para páginas web em Next.js consumindo Snowflake (camada ouro).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "doctor": "node scripts/doctor.mjs",
    "migrate": "node scripts/migrate.mjs",
    "dashboard:init": "node scripts/init-dashboard.mjs",
    "pbip:check": "node scripts/check-pbip.mjs",
    "pbip:inventory": "node scripts/inventory-pbip.mjs",
    "dax:extract": "node scripts/extract-dax-measures.mjs",
    "dax:classify": "node scripts/classify-dax-complexity.mjs",
    "dax:review-cards": "node scripts/create-dax-review-cards.mjs",
    "validation:init": "node scripts/create-validation-folders.mjs",
    "snowflake:check": "node scripts/check-snowflake-env.mjs",
    "snowflake:test": "node scripts/test-snowflake-connection.mjs",
    "validate:python": "python validation/compare-results.py"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.473.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "snowflake-sdk": "^2.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
